<Window x:Class="BancPac.WpfClient.SsrsWebView2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="BancPac 360 Reports" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- login panel (hidden after auth) -->
            <RowDefinition Height="*"/>      <!-- WebView2 -->
        </Grid.RowDefinitions>

        <!-- Login panel - shown only before authentication -->
        <Border x:Name="LoginPanel" Grid.Row="0"
                Background="#F0F0F0" Padding="12" Visibility="Visible">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="User ID:"   VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox   x:Name="TxtUid"   Width="120" Margin="0,0,12,0"/>
                <TextBlock Text="Password:"  VerticalAlignment="Center" Margin="0,0,4,0"/>
                <PasswordBox x:Name="TxtPwd" Width="120" Margin="0,0,12,0"/>
                <TextBlock Text="Bank #:"    VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox   x:Name="TxtBnbr" Width="80"  Margin="0,0,12,0"/>
                <Button    x:Name="BtnLogin" Content="Log In" Width="80"
                           Click="BtnLogin_Click"/>
                <TextBlock x:Name="TxtError" Foreground="Red"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Loading overlay shown while authenticating -->
        <Border x:Name="LoadingOverlay" Grid.Row="1"
                Background="White" Visibility="Collapsed"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Text="Signing in..." FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- The WebView2 control - replace IE WebBrowser -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1"
                      Visibility="Collapsed"
                      NavigationCompleted="WebView_NavigationCompleted"/>
    </Grid>
</Window>
