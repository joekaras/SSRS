<Window x:Class="WpfTestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="UILogon / WebView2 Test Harness" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="300"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             LEFT PANEL — config, credentials, actions, log
             ═══════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="10">

            <!-- SERVER CONFIG -->
            <GroupBox DockPanel.Dock="Top" Header="Server Configuration" Padding="8">
                <StackPanel>
                    <Label>SSRS Base URL</Label>
                    <TextBox x:Name="TxtBaseUrl" Text="http://vmlenovo"/>

                    <Label>UILogon Path</Label>
                    <TextBox x:Name="TxtUILogonPath" Text="/ReportServer/UILogon.aspx"/>

                    <Label>Report URL (after login)</Label>
                    <TextBox x:Name="TxtReportUrl" Text="http://vmlenovo/Reports"/>

                    <Label>Shared Key (UILogon.Key1 or Key2)</Label>
                    <PasswordBox x:Name="TxtKey"/>
                </StackPanel>
            </GroupBox>

            <!-- CREDENTIALS -->
            <GroupBox DockPanel.Dock="Top" Header="Credentials" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <Label>UID (User ID)</Label>
                    <TextBox x:Name="TxtUid"/>

                    <Label>PWD (Password / KeyP)</Label>
                    <PasswordBox x:Name="TxtPwd"/>

                    <Label>BNBR (Bank Number — blank if using Key2)</Label>
                    <TextBox x:Name="TxtBnbr"/>
                </StackPanel>
            </GroupBox>

            <!-- ACTIONS -->
            <GroupBox DockPanel.Dock="Top" Header="Test Steps" Padding="8" Margin="0,8,0,0">
                <StackPanel>
                    <Button x:Name="BtnStep1" Content="Step 1 — POST to UILogon.aspx (HttpClient only)"
                            Click="BtnStep1_Click"/>
                    <Button x:Name="BtnStep2" Content="Step 2 — Inject cookie → Navigate WebView2"
                            Click="BtnStep2_Click" IsEnabled="False"/>
                    <Button x:Name="BtnFullFlow" Content="Run Full Flow (Steps 1 + 2)"
                            Click="BtnFullFlow_Click" Background="#E8F5E9"/>
                    <Separator Margin="0,8"/>
                    <Button x:Name="BtnNavigateDirect" Content="Navigate WebView2 (no auth — test redirect)"
                            Click="BtnNavigateDirect_Click"/>
                    <Button x:Name="BtnClearCookies" Content="Clear WebView2 Cookies"
                            Click="BtnClearCookies_Click"/>
                    <Button x:Name="BtnClearLog" Content="Clear Log"
                            Click="BtnClearLog_Click" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>

            <!-- STATUS -->
            <Border DockPanel.Dock="Top" Margin="0,8,0,0" Padding="8"
                    Background="#F5F5F5" BorderBrush="#CCC" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Status" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtStatus" TextWrapping="Wrap" Margin="0,4,0,0"
                               FontFamily="Consolas" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Cookie: " FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtCookieState" Text="None" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LOG -->
            <GroupBox DockPanel.Dock="Fill" Header="Log" Padding="4" Margin="0,8,0,0">
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLog" FontFamily="Consolas" FontSize="11"
                               TextWrapping="Wrap" Padding="4"/>
                </ScrollViewer>
            </GroupBox>
        </DockPanel>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="#DDD"/>

        <!-- ═══════════════════════════════════════════════════════════
             RIGHT PANEL — WebView2
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Address bar -->
            <DockPanel Grid.Row="0" Margin="4">
                <Button DockPanel.Dock="Right" Content="Go" Width="40"
                        Click="BtnGo_Click" Margin="4,0,0,0"/>
                <TextBox x:Name="TxtAddress" FontFamily="Consolas"
                         KeyDown="TxtAddress_KeyDown"
                         VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- WebView2 -->
            <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1">
                <wv2:WebView2 x:Name="WebView"
                              NavigationStarting="WebView_NavigationStarting"
                              NavigationCompleted="WebView_NavigationCompleted"
                              SourceChanged="WebView_SourceChanged"/>
            </Border>
        </Grid>
    </Grid>
</Window>
