<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <!--
    These values pre-populate the test app's fields on startup.
    You can also edit them directly in the UI without restarting.

    UILogon.Key must match UILogon.Key1 or UILogon.Key2 in
    BancPac.ReportingServices.BP360.dll.config on the server.
    Do NOT commit a real key value to source control.
  -->
  <appSettings>
    <!--<add key="SSRS.BaseUrl"     value="http://vmlenovo"/>
    <add key="SSRS.UILogonPath" value="/ReportServer/logon.aspx"/>
    <add key="SSRS.ReportUrl"   value="http://vmlenovo/Reports"/>-->
    <add key="SSRS.BaseUrl" value="http://vwmazbp360test/" />
    <add key="SSRS.UILogonPath" value="/ReportServer/logon.aspx" />
    <add key="SSRS.ReportUrl" value="http://vwmazbp360test/Reports" />
    <!-- Leave UILogon.Key blank here; enter it at runtime in the UI -->
    <add key="UILogon.Key" value="" />
  </appSettings>
</configuration>